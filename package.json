{
  "name": "teams-wake",
  "version": "1.0.4",
  "description": "Keep Microsoft Teams active on macOS",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "keywords": [
    "teams",
    "keep-alive",
    "macOS",
    "mouse-jiggler"
  ],
  "author": "Antigravity",
  "license": "MIT",
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.linrol.teamswake",
    "productName": "Teams Wake",
    "mac": {
      "category": "public.app-category.utilities",
      "target": [
        "dmg"
      ],
      "icon": "assets/icon.png",
      "hardenedRuntime": false,
      "gatekeeperAssess": false
    },
    "dmg": {
      "backgroundColor": "#12161e",
      "window": {
        "width": 540,
        "height": 380
      },
      "contents": [
        {
          "x": 130,
          "y": 150,
          "type": "file"
        },
        {
          "x": 410,
          "y": 150,
          "type": "link",
          "path": "/Applications"
        }
      ]
    }
  }
}
